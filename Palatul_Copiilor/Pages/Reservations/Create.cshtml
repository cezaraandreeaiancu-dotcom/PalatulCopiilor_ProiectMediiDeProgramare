@page
@model Palatul_Copiilor.Pages.Reservations.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Reservation</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <!-- IMPORTANT: asta trimite ActivityId la POST -->
            <input type="hidden" asp-for="Reservation.ActivityId" />

            <div class="form-group">
                <label class="control-label">Activitate</label>
                <input class="form-control" value="@Model.ActivityTitle" readonly />
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Rezervă" class="btn btn-primary" />
            </div>
        </form>

        <div class="mt-3">
            <a asp-page="Index">Back to List</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
