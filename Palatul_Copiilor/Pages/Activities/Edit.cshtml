@page
@model Palatul_Copiilor.Pages.Activities.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Activity</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Activity.Id" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Activity.Title" class="control-label"></label>
                <input asp-for="Activity.Title" class="form-control" aria-required="true"/>
                <span asp-validation-for="Activity.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Activity.Description" class="control-label"></label>
                <input asp-for="Activity.Description" class="form-control" />
                <span asp-validation-for="Activity.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Activity.StartAt" class="control-label"></label>
                <input asp-for="Activity.StartAt" class="form-control" aria-required="true"/>
                <span asp-validation-for="Activity.StartAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Activity.DepartmentId" class="control-label"></label>
                <select asp-for="Activity.DepartmentId" class="form-control" asp-items="ViewBag.DepartmentId" ></select>
                <span asp-validation-for="Activity.DepartmentId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Activity.TeacherId" class="control-label"></label>
                <select asp-for="Activity.TeacherId" class="form-control" asp-items="ViewBag.TeacherId"></select>
                <span asp-validation-for="Activity.TeacherId" class="text-danger"></span>
            </div>



            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
