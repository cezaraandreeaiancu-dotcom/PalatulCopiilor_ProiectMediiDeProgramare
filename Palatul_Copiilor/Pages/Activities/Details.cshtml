@page
@model Palatul_Copiilor.Pages.Activities.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Activity</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Activity.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Activity.Title)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Activity.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Activity.Description)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Activity.StartAt)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Activity.StartAt)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Activity.Department)
        </dt>
        <dd class="col-sm-10">
            @(Model.Activity.Department != null ? Model.Activity.Department.Name : "-")
        </dd>
    </dl>
</div>

<hr />
<h4>Recenzii (anonime)</h4>

@if (Model.AverageRating == null)
{
    <p>Încă nu există recenzii pentru această activitate.</p>
}
else
{
    <p><strong>Rating mediu:</strong> @Model.AverageRating.Value.ToString("0.00") / 5</p>

    <ul>
        @foreach (var r in Model.Reviews)
        {
            <li>
                <strong>@r.Rating / 5</strong>
                <span> — @r.CreatedAt.ToString("dd.MM.yyyy")</span>

                @if (!string.IsNullOrWhiteSpace(r.Comment))
                {
                    <div>@r.Comment</div>
                }
            </li>
        }
    </ul>
}

<div class="mt-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-page="./Edit" asp-route-id="@Model.Activity.Id">Edit</a>
        <span> | </span>
    }
    <a asp-page="./Index">Back to List</a>
</div>
