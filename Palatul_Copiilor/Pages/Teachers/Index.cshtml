@page
@model Palatul_Copiilor.Pages.Teachers.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Profesori coordonatori</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-page="Create">Create New</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Teacher[0].FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Teacher[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Teacher[0].Phone)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Teacher) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FullName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a>
                        <span> | </span>
                        <a asp-page="./Details" asp-route-id="@item.Id">Details</a>
                        <span> | </span>
                        <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                    }
                    else
                    {
                        <a asp-page="./Details" asp-route-id="@item.Id">Details</a>
                    }
                </td>

            </td>
        </tr>
}
    </tbody>
</table>
